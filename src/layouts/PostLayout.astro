---
import Base from './Base.astro';
interface Props {
title: string;
date?: Date;
description?: string;
tags?: string[];
backHref: string;
backLabel: string;
}

const { title, date, description, tags, backHref, backLabel } = Astro.props;
---

<Base title={title}>
<article>
    <a class="back" href={backHref}>← {backLabel}</a>
    <div class="post-header">
        <h1 class="post-title">{title}</h1>
        {description && <p class="post-desc">{description}</p>}
        <div class="post-meta">
            <span class="post-date">
                {date?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
            {tags && (
            <div class="post-tags">
                {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            )}
        </div>
    </div>
    <div class="divider"></div>
    <div class="prose">
        <slot />
    </div>
</article>
</Base>

<style>
    .back {
        font-size: 14px;
        color: #444;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 2rem;
    }

    .back:hover {
        color: #888;
    }

    .post-header {
        margin-bottom: 0;
    }

    .post-title {
        font-size: 32px;
        font-weight: 600;
        color: #e8e8e8;
        letter-spacing: -0.02em;
        line-height: 1.3;
        margin-bottom: 0.6rem;
    }

    .post-desc {
        font-size: 14px;
        color: #555;
        line-height: 1.6;
        margin-bottom: 0.8rem;
    }

    .post-meta {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .post-date {
        font-size: 11px;
        color: #333;
    }

    .post-tags {
        display: flex;
        gap: 6px;
    }

    .tag {
        font-size: 10px;
        color: #3a3a3a;
        border: 1px solid #222;
        padding: 1px 6px;
        border-radius: 3px;
    }

    .divider {
        height: 1px;
        background: #222;
        margin: 1.6rem 0;
    }

    .prose {
        color: #eee;
        line-height: 1.9;
        font-size: 16px;
    }

    .prose h2,
    .prose h3 {
        font-size: 13px;
        font-weight: 600;
        color: #ccc;
        margin: 2rem 0 0.6rem;
        letter-spacing: -0.01em;
    }

    .prose p {
        margin-bottom: 1rem;
    }

    .prose a {
        color: #666;
        text-underline-offset: 3px;
    }

    .prose a:visited {
        color: #666;
    }

    .prose ul,
    .prose ol {
        padding-left: 1.2rem;
        margin-bottom: 1rem;
    }

    .prose li {
        margin-bottom: 0.3rem;
    }

    .prose code {
        background: #161616;
        border: 1px solid #1e1e1e;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 11px;
        color: #aaa;
    }

    .prose pre {
        background: #161616;
        border: 1px solid #1e1e1e;
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        margin-bottom: 1rem;
    }

    .prose blockquote {
        border-left: 2px solid #222;
        padding-left: 1rem;
        color: #555;
        margin: 1rem 0;
    }
</style>