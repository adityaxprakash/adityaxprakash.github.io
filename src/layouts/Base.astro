---
interface Props {
title: string;
}
const { title } = Astro.props;
---

<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title} | adityaprakash</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet">
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Manrope', monospace;
      background: #0e0e0e;
      color: #c8c8c8;
      font-size: 16px;
      line-height: 1.7;
      display: flex;
      min-height: 100vh;
    }

    a {
      color: #c8c8c8;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: #333;
    }

    a:hover {
      color: #fff;
      text-decoration-color: #888;
    }

    nav {
      width: 250px;
      min-width: 240px;
      padding: 2rem 1.5rem;
      background: #161616;
      border-right: 1px solid #252525;
      display: flex;
      flex-direction: column;
    }

    nav .logo {
      font-size: 18px;
      font-weight: 600;
      color: #e8e8e8;
      margin-bottom: 2.5rem;
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      letter-spacing: -0.01em;
    }

    nav .logo img {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      border: 1px solid #2a2a2a;
    }

    nav .section-label {
      font-size: 16px;
      color: #3a3a3a;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      margin-top: 1.5rem;
    }

    nav .section-label:first-of-type {
      margin-top: 0;
    }

    nav ul {
      list-style: none;
    }

    nav li {
      margin-bottom: 1px;
    }

    nav a {
      color: #666;
      font-size: 16px;
      text-decoration: none;
      display: block;
      padding: 3px 0;
    }

    nav a:hover {
      color: #d0d0d0;
    }

    nav a.active {
      color: #d0d0d0;
    }

    footer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.6rem 1.5rem;
      font-size: 12px;
      color: #eee;
      border-top: 1px solid #1a1a1a;
      background: #0e0e0e;
      display: flex;
      justify-content: space-between;
    }

    footer a {
      color: #eee;
      font-size: 12px;
      text-decoration-color: #2a2a2a;
    }

    footer a:hover {
      color: #888;
    }

    main {
      flex: 1;
      padding: 2.5rem 3rem 3rem;
      max-width: 900px;
    }

    @media (max-width: 768px) {
      body {
        flex-direction: column;
      }

      nav {
        width: 100%;
        min-width: unset;
        border-right: none;
        border-bottom: 1px solid #252525;
        padding: 1.2rem 1.5rem;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }

      nav .logo {
        margin-bottom: 0;
      }

      nav .section-label {
        display: none;
      }

      nav ul {
        display: flex;
        flex-direction: row;
        gap: 16px;
      }

      nav li {
        margin-bottom: 0;
      }

      main {
        padding: 1.5rem;
        max-width: 100%;
      }

      footer {
        font-size: 10px;
        padding: 0.6rem 1.5rem;
      }
      footer a {
      color: #eee;
      font-size: 10px;
      text-decoration-color: #2a2a2a;
    }

    footer a:hover {
      color: #888;
    }
    }
  </style>
</head>

<body>
  <nav>
    <a class="logo" href="/">
      <img src="https://github.com/adityaxprakash.png" alt="avatar" />
      aditya prakash
    </a>
    <ul>
      <li><a href="/">home</a></li>
      <li><a href="/blog">blog</a></li>
      <li><a href="/poems">poems</a></li>
    </ul>
  </nav>
  <main>
    <slot />
  </main>

  <footer>
    <span>made out of ❤️ & boredom</span>
    <span>built with <a href="https://astro.build" target="_blank">astro • inspired by <a href="https://namishh.com"
          target="_blank">namishh</a></a></span>
  </footer>
</body>

</html>