---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const poems = (await getCollection('poems', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<Base title="poems">
  <section>
    <div class="section-header">
      <h2>poems</h2>
      <p>things i wrote when i felt something.</p>
    </div>
    <ul class="post-list">
      {poems.map(p => (
        <li class="post-item">
          <a href={`/poems/${p.id}`}>{p.data.title}</a>
          <div class="post-meta">
            <span class="post-date">{p.data.date?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          </div>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  section { margin-top: 0; }

  .section-header { margin-bottom: 2rem; }
  .section-header h2 {
    font-size: 32px;
    font-weight: 600;
    color: #e8e8e8;
    letter-spacing: -0.02em;
    margin-bottom: 0.3rem;
  }
  .section-header p { font-size: 14px; color: #444; }

  .post-list { list-style: none; padding: 0; }

  .post-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.9rem 0;
    border-bottom: 1px solid #2b2b2b;
  }
  .post-item:first-child { border-top: 1px solid #2b2b2b; }

  .post-item a { font-size: 20px; color: #eee; text-decoration: none; }
  .post-item a:visited { color: #eee; }
  .post-item a:hover { color: #fff; }

  .post-date { font-size: 11px; color: #333; }
</style>